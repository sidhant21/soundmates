{
  "expo": {
    "name": "SoundMates",
    "slug": "soundmates",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "soundmates",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.sidhant21.soundmates"
    },
    "web": {
      "favicon": "./assets/images/icon.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1c7b3ea3-bca8-4f09-b633-ca1c23cc3f94"
      }
    }
  }
}
